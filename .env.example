ENVIRONMENT=development
AUTOMATISATIONS_IMAGE=ghcr.io/gderamchi/automatisations:main
API_HOST=0.0.0.0
API_PORT=8080
PUBLIC_BASE_URL=http://127.0.0.1:8080
DATA_ROOT=/data
DB_PATH=/data/state/sqlite/automation.db
INTERNAL_API_TOKEN=change-me-internal-token
INTERNAL_API_BASE_URL=http://api:8080
VALIDATION_USERNAME=validator
VALIDATION_PASSWORD=change-me-validation-password
OCR_CONFIDENCE_THRESHOLD=0.82
OCR_MOCK_MODE=true
MISTRAL_API_KEY=
MISTRAL_OCR_MODEL=mistral-ocr-latest
IMAP_HOST=imap.gmail.com
IMAP_PORT=993
IMAP_USERNAME=
IMAP_PASSWORD=
IMAP_MAILBOX=INBOX
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=
REPLY_TO_EMAIL=
MAIL_POLL_SECONDS=30
MAIL_REPLY_SUBJECT_PREFIX=[AUTOMATISATIONS OCR]
MARK_PROCESSED_SEEN=true
MAIL_BOOTSTRAP_CURRENT_UID=true
INTERFAST_BASE_URL=
INTERFAST_API_KEY=
INTERFAST_TIMEOUT_SECONDS=30
INTERFAST_WRITE_MODE=disabled
INTERFAST_ATTACHMENT_FIELD_NAME=file
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
EXPORT_DELIMITER=;
EXPORT_ENCODING=utf-8-sig
BANK_MATCH_CERTAIN_THRESHOLD=0.92
BANK_MATCH_PROBABLE_THRESHOLD=0.7
ROUTING_MATCH_THRESHOLD=0.72
ROUTING_MATCH_GAP=0.10
ROUTING_AUTO_DISPATCH=true
DASHBOARD_REFRESH_SECONDS=30
WEEKLY_ACCOUNTING_RECIPIENT=
WEEKLY_ACCOUNTING_SUBJECT_PREFIX=COMPTABILITÉ
CLIENT_GRAND_LIVRE_WORKBOOK_PATH=
