{
  "name": "Bank Import And Export",
  "nodes": [
    {
      "id": "1",
      "name": "Manual Trigger",
      "type": "n8n-nodes-base.manualTrigger",
      "typeVersion": 1,
      "position": [
        220,
        260
      ],
      "parameters": {}
    },
    {
      "id": "2",
      "name": "Import Bank CSV",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        480,
        260
      ],
      "parameters": {
        "method": "POST",
        "url": "http://api:8080/internal/bank/import",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "X-Internal-Token",
              "value": "={{$env.INTERNAL_API_TOKEN}}"
            }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\"csv_path\":\"/data/incoming/manual/releve.csv\"}"
      }
    },
    {
      "id": "3",
      "name": "Export Inexweb",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        760,
        260
      ],
      "parameters": {
        "method": "POST",
        "url": "http://api:8080/internal/exports/inexweb",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "X-Internal-Token",
              "value": "={{$env.INTERNAL_API_TOKEN}}"
            }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={}"
      }
    }
  ],
  "connections": {
    "Manual Trigger": {
      "main": [
        [
          {
            "node": "Import Bank CSV",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Import Bank CSV": {
      "main": [
        [
          {
            "node": "Export Inexweb",
            "type": "main",
            "index": 0
          }
        ]
      ]
    }
  },
  "active": false
}
